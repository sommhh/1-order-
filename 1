<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>品番読み取り注文アプリ</title>
<script src="https://cdn.jsdelivr.net/npm/tesseract.js@4/dist/tesseract.min.js"></script>

<style>
body {
  font-family: sans-serif;
  padding: 10px;
  background: #f5f5f5;
}
button {
  padding: 10px;
  margin: 5px 0;
  width: 100%;
  font-size: 16px;
}
input {
  width: 60px;
}
.item {
  background: white;
  padding: 10px;
  margin: 5px 0;
  border-radius: 8px;
}
</style>
</head>

<body>

<h2>📸 品番読み取り注文</h2>

<input type="file" accept="image/*" capture="environment" id="camera">

<button onclick="readOCR()">🔍 読み取り</button>

<div id="status"></div>

<h3>📋 リスト</h3>
<div id="list"></div>

<button onclick="sendLine()">📤 LINEで注文</button>

<script>
let items = [];

async function readOCR() {
  const file = document.getElementById('camera').files[0];
  if (!file) return alert("写真を選んで");

  document.getElementById("status").innerText = "読み取り中...";

  const result = await Tesseract.recognize(file, 'eng');
  const text = result.data.text;

  const codes = extractCodes(text);

  if (codes.length === 0) {
    alert("品番が見つからない");
  }

  codes.forEach(code => addItem(code));

  document.getElementById("status").innerText = "完了";
}

function extractCodes(text) {
  const regex = /[A-Z0-9\-]{4,}/g;
  return text.match(regex) || [];
}

function addItem(code) {
  // 同じ品番はまとめる
  const existing = items.find(i => i.code === code);
  if (existing) {
    existing.qty++;
  } else {
    items.push({ code: code, qty: 1 });
  }
  render();
}

function render() {
  const list = document.getElementById("list");
  list.innerHTML = "";

  items.forEach((item, index) => {
    list.innerHTML += `
      <div class="item">
        <b>${item.code}</b><br>
        数量:
        <input type="number" value="${item.qty}" 
          onchange="updateQty(${index}, this.value)">
        <button onclick="removeItem(${index})">削除</button>
      </div>
    `;
  });
}

function updateQty(index, qty) {
  items[index].qty = Number(qty);
}

function removeItem(index) {
  items.splice(index, 1);
  render();
}

function sendLine() {
  if (items.length === 0) return alert("商品がない");

  let message = "【注文リスト】\n";

  items.forEach(i => {
    message += `${i.code} × ${i.qty}\n`;
  });

  const url = "https://line.me/R/msg/text/?" + encodeURIComponent(message);
  window.open(url);
}
</script>

</body>
</html>
